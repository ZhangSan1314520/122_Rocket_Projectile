  92:My_Top/EEPROM/XBLW24C64.cpp ****                                EEPROM_ADDR_SIZE,
  93:My_Top/EEPROM/XBLW24C64.cpp ****                                (uint8_t *)buf, chunk, 100) != HAL_OK)
  94:My_Top/EEPROM/XBLW24C64.cpp ****         {
  95:My_Top/EEPROM/XBLW24C64.cpp ****             return false;
  96:My_Top/EEPROM/XBLW24C64.cpp ****         }
  97:My_Top/EEPROM/XBLW24C64.cpp **** 
  98:My_Top/EEPROM/XBLW24C64.cpp ****         // 等待内部写入完成
  99:My_Top/EEPROM/XBLW24C64.cpp ****         _wait_write_complete();
 100:My_Top/EEPROM/XBLW24C64.cpp **** 
 101:My_Top/EEPROM/XBLW24C64.cpp ****         addr += chunk;
 102:My_Top/EEPROM/XBLW24C64.cpp ****         buf  += chunk;
