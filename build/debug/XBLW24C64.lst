  76:My_Top/EEPROM/XBLW24C64.cpp **** // 连续写入多个字节（自动处理页边界）
  77:My_Top/EEPROM/XBLW24C64.cpp **** // ============================================================
  78:My_Top/EEPROM/XBLW24C64.cpp **** bool XBLW24C64::write(uint16_t addr, const uint8_t *buf, uint16_t len)
  79:My_Top/EEPROM/XBLW24C64.cpp **** {
  80:My_Top/EEPROM/XBLW24C64.cpp ****     if (buf == NULL || len == 0)
  81:My_Top/EEPROM/XBLW24C64.cpp ****         return false;
  82:My_Top/EEPROM/XBLW24C64.cpp ****     if (addr + len > EEPROM_SIZE)
  83:My_Top/EEPROM/XBLW24C64.cpp ****         return false;
  84:My_Top/EEPROM/XBLW24C64.cpp **** 
  85:My_Top/EEPROM/XBLW24C64.cpp ****     while (len > 0)
  86:My_Top/EEPROM/XBLW24C64.cpp ****     {
  87:My_Top/EEPROM/XBLW24C64.cpp ****         // 计算当前页内还能写多少字节
  88:My_Top/EEPROM/XBLW24C64.cpp ****         uint8_t page_remain = EEPROM_PAGE_SIZE - (addr % EEPROM_PAGE_SIZE);
  89:My_Top/EEPROM/XBLW24C64.cpp ****         uint16_t chunk = (len < page_remain) ? len : page_remain;//等价于min(len, page_remain);
  90:My_Top/EEPROM/XBLW24C64.cpp **** 
