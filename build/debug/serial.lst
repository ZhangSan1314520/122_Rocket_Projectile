  41:Lib/serial/serial.cpp **** // init - 完整初始化串口（需要所有参数）
  42:Lib/serial/serial.cpp **** // 参数：
  43:Lib/serial/serial.cpp **** //   name   - 串口名称（用于任务命名，最大 SERIAL_NAME_SIZE 字符）
  44:Lib/serial/serial.cpp **** //   config - 串口配置结构体指针
  45:Lib/serial/serial.cpp **** //   uart   - CubeMX 生成的 UART 句柄指针
  46:Lib/serial/serial.cpp **** // 返回：true 成功，false 失败
  47:Lib/serial/serial.cpp **** // ============================================================
  48:Lib/serial/serial.cpp **** bool Serial::init(const char *name, Serial_Config *config, UART_HandleTypeDef *uart)
  49:Lib/serial/serial.cpp **** {
  50:Lib/serial/serial.cpp ****     // -------------------- 1. 参数合法性检查 --------------------
  51:Lib/serial/serial.cpp ****     if (name == NULL || config == NULL || uart == NULL)
  52:Lib/serial/serial.cpp ****     {
  53:Lib/serial/serial.cpp ****         _error = Serial_Error::Init_Error;  // 记录错误类型
  54:Lib/serial/serial.cpp ****         return false;
  55:Lib/serial/serial.cpp ****     }
  56:Lib/serial/serial.cpp **** 
  57:Lib/serial/serial.cpp ****     // -------------------- 2. 配置参数合理性检查 --------------------
  58:Lib/serial/serial.cpp ****     // 名称长度检查（防止溢出）
  59:Lib/serial/serial.cpp ****     // strnlen 返回字符串长度，超过 SERIAL_NAME_SIZE 则报错
  60:Lib/serial/serial.cpp ****     if (strnlen(name, SERIAL_NAME_SIZE * 2) >= SERIAL_NAME_SIZE ||
  61:Lib/serial/serial.cpp ****         // 接收/发送模式不能是 None（否则无法工作）
  62:Lib/serial/serial.cpp ****         config->rx_mode == Serial_Mode::None || config->tx_mode == Serial_Mode::None ||
  63:Lib/serial/serial.cpp ****         // 数据包大小必须 > 0
  64:Lib/serial/serial.cpp ****         config->rx_pack_size == 0 || config->tx_pack_size == 0 ||
  65:Lib/serial/serial.cpp ****         // 队列长度必须 > 0
  66:Lib/serial/serial.cpp ****         config->rx_queue_len == 0 || config->tx_queue_len == 0)
  67:Lib/serial/serial.cpp ****     {
  68:Lib/serial/serial.cpp ****         _error = Serial_Error::Init_Error;
  69:Lib/serial/serial.cpp ****         return false;
  70:Lib/serial/serial.cpp ****     }
  71:Lib/serial/serial.cpp **** 
  72:Lib/serial/serial.cpp ****     // -------------------- 3. 清零实例成员 --------------------
  73:Lib/serial/serial.cpp ****     memset(_name, 0, sizeof(_name));      // 清零名称缓冲区
  74:Lib/serial/serial.cpp ****     memset(&_config, 0, sizeof(_config)); // 清零配置结构体
  75:Lib/serial/serial.cpp ****     memset(&_info, 0, sizeof(_info));    // 清零统计信息结构体
  76:Lib/serial/serial.cpp **** 
  77:Lib/serial/serial.cpp ****     // -------------------- 4. 复制配置 --------------------
  78:Lib/serial/serial.cpp ****     strncpy(_name, name, SERIAL_NAME_SIZE);  // 复制串口名称
  79:Lib/serial/serial.cpp ****     _config = *config;                        // 复制配置参数
  80:Lib/serial/serial.cpp ****     _uart = uart;                             // 保存 UART 句柄
  81:Lib/serial/serial.cpp **** 
  82:Lib/serial/serial.cpp ****     // -------------------- 5. 注册到全局串口列表 --------------------
