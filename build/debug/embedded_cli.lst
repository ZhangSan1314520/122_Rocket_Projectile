 833:Lib/embedded-cli/embedded_cli.c **** static void parseCommand(EmbeddedCli *cli) {
 834:Lib/embedded-cli/embedded_cli.c ****     PREPARE_IMPL(cli);
 835:Lib/embedded-cli/embedded_cli.c **** 
 836:Lib/embedded-cli/embedded_cli.c ****     bool isEmpty = true;
 837:Lib/embedded-cli/embedded_cli.c **** 
 838:Lib/embedded-cli/embedded_cli.c ****     for (int i = 0; i < impl->cmdSize; ++i) {
 839:Lib/embedded-cli/embedded_cli.c ****         if (impl->cmdBuffer[i] != ' ') {
 840:Lib/embedded-cli/embedded_cli.c ****             isEmpty = false;
 841:Lib/embedded-cli/embedded_cli.c ****             break;
 842:Lib/embedded-cli/embedded_cli.c ****         }
 843:Lib/embedded-cli/embedded_cli.c ****     }
 844:Lib/embedded-cli/embedded_cli.c ****     // do not process empty commands
 845:Lib/embedded-cli/embedded_cli.c ****     if (isEmpty)
 846:Lib/embedded-cli/embedded_cli.c ****         return;
 847:Lib/embedded-cli/embedded_cli.c ****     // push command to history before buffer is modified
 848:Lib/embedded-cli/embedded_cli.c ****     historyPut(&impl->history, impl->cmdBuffer);
 849:Lib/embedded-cli/embedded_cli.c **** 
 850:Lib/embedded-cli/embedded_cli.c ****     char *cmdName = NULL;
 851:Lib/embedded-cli/embedded_cli.c ****     char *cmdArgs = NULL;
 852:Lib/embedded-cli/embedded_cli.c ****     bool nameFinished = false;
 853:Lib/embedded-cli/embedded_cli.c **** 
 854:Lib/embedded-cli/embedded_cli.c ****     // find command name and command args inside command buffer
 855:Lib/embedded-cli/embedded_cli.c ****     for (int i = 0; i < impl->cmdSize; ++i) {
 856:Lib/embedded-cli/embedded_cli.c ****         char c = impl->cmdBuffer[i];
 857:Lib/embedded-cli/embedded_cli.c **** 
 858:Lib/embedded-cli/embedded_cli.c ****         if (c == ' ') {
 859:Lib/embedded-cli/embedded_cli.c ****             // all spaces between name and args are filled with zeros
 860:Lib/embedded-cli/embedded_cli.c ****             // so name is a correct null-terminated string
 861:Lib/embedded-cli/embedded_cli.c ****             if (cmdArgs == NULL)
 862:Lib/embedded-cli/embedded_cli.c ****                 impl->cmdBuffer[i] = '\0';
 863:Lib/embedded-cli/embedded_cli.c ****             if (cmdName != NULL)
 864:Lib/embedded-cli/embedded_cli.c ****                 nameFinished = true;
 865:Lib/embedded-cli/embedded_cli.c **** 
 866:Lib/embedded-cli/embedded_cli.c ****         } else if (cmdName == NULL) {
 867:Lib/embedded-cli/embedded_cli.c ****             cmdName = &impl->cmdBuffer[i];
 868:Lib/embedded-cli/embedded_cli.c ****         } else if (cmdArgs == NULL && nameFinished) {
 869:Lib/embedded-cli/embedded_cli.c ****             cmdArgs = &impl->cmdBuffer[i];
 870:Lib/embedded-cli/embedded_cli.c ****         }
 871:Lib/embedded-cli/embedded_cli.c ****     }
 872:Lib/embedded-cli/embedded_cli.c **** 
 873:Lib/embedded-cli/embedded_cli.c ****     // we keep two last bytes in cmd buffer reserved so cmdSize is always by 2
 874:Lib/embedded-cli/embedded_cli.c ****     // less than cmdMaxSize
 875:Lib/embedded-cli/embedded_cli.c ****     impl->cmdBuffer[impl->cmdSize + 1] = '\0';
 876:Lib/embedded-cli/embedded_cli.c **** 
 877:Lib/embedded-cli/embedded_cli.c ****     if (cmdName == NULL)
 878:Lib/embedded-cli/embedded_cli.c ****         return;
 879:Lib/embedded-cli/embedded_cli.c **** 
 880:Lib/embedded-cli/embedded_cli.c ****     // try to find command in bindings
 881:Lib/embedded-cli/embedded_cli.c ****     for (int i = 0; i < impl->bindingsCount; ++i) {
 882:Lib/embedded-cli/embedded_cli.c ****         if (strcmp(cmdName, impl->bindings[i].name) == 0) {
 883:Lib/embedded-cli/embedded_cli.c ****             if (impl->bindings[i].binding == NULL)
 884:Lib/embedded-cli/embedded_cli.c ****                 break;
 885:Lib/embedded-cli/embedded_cli.c **** 
