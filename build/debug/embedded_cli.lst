 903:Lib/embedded-cli/embedded_cli.c ****     if (cli->onCommand != NULL) {
 904:Lib/embedded-cli/embedded_cli.c ****         CliCommand command;
 905:Lib/embedded-cli/embedded_cli.c ****         command.name = cmdName;
 906:Lib/embedded-cli/embedded_cli.c ****         command.args = cmdArgs;
