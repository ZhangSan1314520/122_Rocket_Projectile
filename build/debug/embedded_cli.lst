ARM GAS  /tmp/ccb99Ich.s 			page 13


 658:Lib/embedded-cli/embedded_cli.c ****         if (currentChar != '\0' || (insertPos > 0 && args[insertPos - 1] != '\0')) {
 659:Lib/embedded-cli/embedded_cli.c ****             args[insertPos] = currentChar;
 660:Lib/embedded-cli/embedded_cli.c ****             ++insertPos;
 661:Lib/embedded-cli/embedded_cli.c ****         }
