 632:Lib/embedded-cli/embedded_cli.c ****     const char *separators = " ";
 633:Lib/embedded-cli/embedded_cli.c **** 
 634:Lib/embedded-cli/embedded_cli.c ****     // indicates that arg is quoted so separators are copied as is
 635:Lib/embedded-cli/embedded_cli.c ****     bool quotesEnabled = false;
