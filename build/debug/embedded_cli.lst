 888:Lib/embedded-cli/embedded_cli.c ****             // currently, output is blank line, so we can just print directly
 889:Lib/embedded-cli/embedded_cli.c ****             SET_FLAG(impl->flags, CLI_FLAG_DIRECT_PRINT);
 890:Lib/embedded-cli/embedded_cli.c ****             // check if help was requested (help is printed when no other options are set)
