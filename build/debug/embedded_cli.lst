 936:Lib/embedded-cli/embedded_cli.c **** static void onHelp(EmbeddedCli *cli, char *tokens, void *context) {
 937:Lib/embedded-cli/embedded_cli.c ****     UNUSED(context);
 938:Lib/embedded-cli/embedded_cli.c ****     PREPARE_IMPL(cli);
 939:Lib/embedded-cli/embedded_cli.c **** 
 940:Lib/embedded-cli/embedded_cli.c ****     if (impl->bindingsCount == 0) {
 941:Lib/embedded-cli/embedded_cli.c ****         writeToOutput(cli, "Help is not available");
