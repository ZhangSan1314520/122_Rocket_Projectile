1193:Lib/embedded-cli/embedded_cli.c **** static bool historyPut(CliHistory *history, const char *str) {
1194:Lib/embedded-cli/embedded_cli.c ****     size_t len = strlen(str);
1195:Lib/embedded-cli/embedded_cli.c ****     // each item is ended with \0 so, need to have that much space at least
1196:Lib/embedded-cli/embedded_cli.c ****     if (history->bufferSize < len + 1)
1197:Lib/embedded-cli/embedded_cli.c ****         return false;
1198:Lib/embedded-cli/embedded_cli.c **** 
1199:Lib/embedded-cli/embedded_cli.c ****     // remove str from history (if it's present) so we don't get duplicates
1200:Lib/embedded-cli/embedded_cli.c ****     historyRemove(history, str);
1201:Lib/embedded-cli/embedded_cli.c **** 
1202:Lib/embedded-cli/embedded_cli.c ****     size_t usedSize;
1203:Lib/embedded-cli/embedded_cli.c ****     // remove old items if new one can't fit into buffer
1204:Lib/embedded-cli/embedded_cli.c ****     while (history->itemsCount > 0) {
1205:Lib/embedded-cli/embedded_cli.c ****         const char *item = historyGet(history, history->itemsCount);
1206:Lib/embedded-cli/embedded_cli.c ****         size_t itemLen = strlen(item);
1207:Lib/embedded-cli/embedded_cli.c ****         usedSize = ((size_t) (item - history->buf)) + itemLen + 1;
1208:Lib/embedded-cli/embedded_cli.c **** 
1209:Lib/embedded-cli/embedded_cli.c ****         size_t freeSpace = history->bufferSize - usedSize;
1210:Lib/embedded-cli/embedded_cli.c **** 
1211:Lib/embedded-cli/embedded_cli.c ****         if (freeSpace >= len + 1)
1212:Lib/embedded-cli/embedded_cli.c ****             break;
1213:Lib/embedded-cli/embedded_cli.c **** 
1214:Lib/embedded-cli/embedded_cli.c ****         // space not enough, remove last element
1215:Lib/embedded-cli/embedded_cli.c ****         --history->itemsCount;
1216:Lib/embedded-cli/embedded_cli.c ****     }
1217:Lib/embedded-cli/embedded_cli.c ****     if (history->itemsCount > 0) {
1218:Lib/embedded-cli/embedded_cli.c ****         // when history not empty, shift elements so new item is first
1219:Lib/embedded-cli/embedded_cli.c ****         memmove(&history->buf[len + 1], history->buf, usedSize);
1220:Lib/embedded-cli/embedded_cli.c ****     }
1221:Lib/embedded-cli/embedded_cli.c ****     memcpy(history->buf, str, len + 1);
1222:Lib/embedded-cli/embedded_cli.c ****     ++history->itemsCount;
1223:Lib/embedded-cli/embedded_cli.c **** 
1224:Lib/embedded-cli/embedded_cli.c ****     return true;
1225:Lib/embedded-cli/embedded_cli.c **** }
1226:Lib/embedded-cli/embedded_cli.c **** 
1227:Lib/embedded-cli/embedded_cli.c **** static const char *historyGet(CliHistory *history, uint16_t item) {
1228:Lib/embedded-cli/embedded_cli.c ****     if (item == 0 || item > history->itemsCount)
1229:Lib/embedded-cli/embedded_cli.c ****         return NULL;
1230:Lib/embedded-cli/embedded_cli.c **** 
1231:Lib/embedded-cli/embedded_cli.c ****     // items are stored in the same way (separated by \0 and counted from 1),
1232:Lib/embedded-cli/embedded_cli.c ****     // so can use this call
1233:Lib/embedded-cli/embedded_cli.c ****     return embeddedCliGetToken(history->buf, item);
1234:Lib/embedded-cli/embedded_cli.c **** }
1235:Lib/embedded-cli/embedded_cli.c **** 
1236:Lib/embedded-cli/embedded_cli.c **** static void historyRemove(CliHistory *history, const char *str) {
1237:Lib/embedded-cli/embedded_cli.c ****     if (str == NULL || history->itemsCount == 0)
1238:Lib/embedded-cli/embedded_cli.c ****         return;
