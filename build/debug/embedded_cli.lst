1240:Lib/embedded-cli/embedded_cli.c ****     uint16_t itemPosition;
1241:Lib/embedded-cli/embedded_cli.c ****     for (itemPosition = 1; itemPosition <= history->itemsCount; ++itemPosition) {
1242:Lib/embedded-cli/embedded_cli.c ****         // items are stored in the same way (separated by \0 and counted from 1),
1243:Lib/embedded-cli/embedded_cli.c ****         // so can use this call
