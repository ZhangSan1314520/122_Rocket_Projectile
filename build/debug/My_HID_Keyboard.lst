 259:My_Top/USB_Composite/My_HID_Keyboard.cpp **** /**
 260:My_Top/USB_Composite/My_HID_Keyboard.cpp ****   * @brief  发送一个 ASCII 字符（自动处理大小写和符号）
 261:My_Top/USB_Composite/My_HID_Keyboard.cpp ****   * @param  c: 要发送的 ASCII 字符（0x00~0x7F）
 262:My_Top/USB_Composite/My_HID_Keyboard.cpp ****   *
 263:My_Top/USB_Composite/My_HID_Keyboard.cpp ****   * 说明：
 264:My_Top/USB_Composite/My_HID_Keyboard.cpp ****   *   - 支持标准 US 键盘布局的全部可打印 ASCII 字符
 265:My_Top/USB_Composite/My_HID_Keyboard.cpp ****   *   - 大写字母自动加 Shift
 266:My_Top/USB_Composite/My_HID_Keyboard.cpp ****   *   - 符号（如 !@#$%）自动加 Shift
 267:My_Top/USB_Composite/My_HID_Keyboard.cpp ****   *   - 非 ASCII（>= 0x80）或控制字符直接忽略
 268:My_Top/USB_Composite/My_HID_Keyboard.cpp ****   *   - 换行符 '\n' 映射为 Enter 键
 269:My_Top/USB_Composite/My_HID_Keyboard.cpp ****   */
 270:My_Top/USB_Composite/My_HID_Keyboard.cpp **** void HID_KB_SendChar(char c)
 271:My_Top/USB_Composite/My_HID_Keyboard.cpp **** {
 272:My_Top/USB_Composite/My_HID_Keyboard.cpp ****     uint8_t idx = (uint8_t)c;
 273:My_Top/USB_Composite/My_HID_Keyboard.cpp **** 
 274:My_Top/USB_Composite/My_HID_Keyboard.cpp ****     /* 非 ASCII，直接返回 */
 275:My_Top/USB_Composite/My_HID_Keyboard.cpp ****     if (idx >= 0x80) {
 276:My_Top/USB_Composite/My_HID_Keyboard.cpp ****         return;
 277:My_Top/USB_Composite/My_HID_Keyboard.cpp ****     }
 278:My_Top/USB_Composite/My_HID_Keyboard.cpp **** 
 279:My_Top/USB_Composite/My_HID_Keyboard.cpp ****     /* 换行符映射为 Enter */
 280:My_Top/USB_Composite/My_HID_Keyboard.cpp ****     if (c == '\n' || c == '\r') {
ARM GAS  /tmp/ccTfUzTX.s 			page 9


 281:My_Top/USB_Composite/My_HID_Keyboard.cpp ****         HID_KB_SendSpecialKey(HID_KEY_ENTER);
 282:My_Top/USB_Composite/My_HID_Keyboard.cpp ****         return;
 283:My_Top/USB_Composite/My_HID_Keyboard.cpp ****     }
 284:My_Top/USB_Composite/My_HID_Keyboard.cpp **** 
 285:My_Top/USB_Composite/My_HID_Keyboard.cpp ****     /* 查找映射表 */
 286:My_Top/USB_Composite/My_HID_Keyboard.cpp ****     uint8_t keycode  = ascii_to_hid[idx].keycode;
 287:My_Top/USB_Composite/My_HID_Keyboard.cpp ****     uint8_t modifier = ascii_to_hid[idx].modifier;
 288:My_Top/USB_Composite/My_HID_Keyboard.cpp **** 
 289:My_Top/USB_Composite/My_HID_Keyboard.cpp ****     /* 未映射（如 DEL 0x7F）直接忽略 */
 290:My_Top/USB_Composite/My_HID_Keyboard.cpp ****     if (keycode == 0x00) {
 291:My_Top/USB_Composite/My_HID_Keyboard.cpp ****         return;
 292:My_Top/USB_Composite/My_HID_Keyboard.cpp ****     }
 293:My_Top/USB_Composite/My_HID_Keyboard.cpp **** 
 294:My_Top/USB_Composite/My_HID_Keyboard.cpp ****     HID_KB_SendKey(modifier, keycode);
 295:My_Top/USB_Composite/My_HID_Keyboard.cpp **** }
 296:My_Top/USB_Composite/My_HID_Keyboard.cpp **** 
 297:My_Top/USB_Composite/My_HID_Keyboard.cpp **** /**
 298:My_Top/USB_Composite/My_HID_Keyboard.cpp ****   * @brief  发送一个 ASCII 字符串（逐字符发送）
 299:My_Top/USB_Composite/My_HID_Keyboard.cpp ****   * @param  str: 要发送的字符串（以 '\0' 结尾）
 300:My_Top/USB_Composite/My_HID_Keyboard.cpp ****   *
 301:My_Top/USB_Composite/My_HID_Keyboard.cpp ****   * 性能：每个字符约 20ms（按下+释放+延时）
 302:My_Top/USB_Composite/My_HID_Keyboard.cpp ****   * 发送 "Hello" 约需 100ms
 303:My_Top/USB_Composite/My_HID_Keyboard.cpp ****   */
 304:My_Top/USB_Composite/My_HID_Keyboard.cpp **** void HID_KB_SendString(const char *str)
 305:My_Top/USB_Composite/My_HID_Keyboard.cpp **** {
 306:My_Top/USB_Composite/My_HID_Keyboard.cpp ****     if (str == NULL) {
 307:My_Top/USB_Composite/My_HID_Keyboard.cpp ****         return;
 308:My_Top/USB_Composite/My_HID_Keyboard.cpp ****     }
 309:My_Top/USB_Composite/My_HID_Keyboard.cpp **** 
 310:My_Top/USB_Composite/My_HID_Keyboard.cpp ****     while (*str != '\0') {
 311:My_Top/USB_Composite/My_HID_Keyboard.cpp ****         HID_KB_SendChar(*str++);
 312:My_Top/USB_Composite/My_HID_Keyboard.cpp ****     }
 313:My_Top/USB_Composite/My_HID_Keyboard.cpp **** }
