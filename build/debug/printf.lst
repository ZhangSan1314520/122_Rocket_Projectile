 169:Lib/serial/printf.c **** // internal secure strlen
 170:Lib/serial/printf.c **** // \return The length of the string (excluding the terminating 0) limited by 'maxsize'
 171:Lib/serial/printf.c **** static inline unsigned int _strnlen_s(const char* str, size_t maxsize)
 172:Lib/serial/printf.c **** {
 173:Lib/serial/printf.c ****   const char* s;
 174:Lib/serial/printf.c ****   for (s = str; *s && maxsize--; ++s);
 175:Lib/serial/printf.c ****   return (unsigned int)(s - str);
 176:Lib/serial/printf.c **** }
 177:Lib/serial/printf.c **** 
 178:Lib/serial/printf.c **** 
 179:Lib/serial/printf.c **** // internal test if char is a digit (0-9)
 180:Lib/serial/printf.c **** // \return true if char is a digit
 181:Lib/serial/printf.c **** static inline bool _is_digit(char ch)
 182:Lib/serial/printf.c **** {
 183:Lib/serial/printf.c ****   return (ch >= '0') && (ch <= '9');
 184:Lib/serial/printf.c **** }
 185:Lib/serial/printf.c **** 
