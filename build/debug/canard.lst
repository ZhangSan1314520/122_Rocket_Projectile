1286:My_Top/Drone_CAN/canard.c **** /**
1287:My_Top/Drone_CAN/canard.c ****  * Puts frame on on the TX queue. Higher priority placed first
1288:My_Top/Drone_CAN/canard.c ****  */
1289:My_Top/Drone_CAN/canard.c **** CANARD_INTERNAL void pushTxQueue(CanardInstance* ins, CanardTxQueueItem* item)
1290:My_Top/Drone_CAN/canard.c **** {
1291:My_Top/Drone_CAN/canard.c ****     CANARD_ASSERT(ins != NULL);
1292:My_Top/Drone_CAN/canard.c ****     CANARD_ASSERT(item->frame.data_len > 0);       // UAVCAN doesn't allow zero-payload frames
1293:My_Top/Drone_CAN/canard.c **** 
1294:My_Top/Drone_CAN/canard.c ****     if (ins->tx_queue == NULL)
1295:My_Top/Drone_CAN/canard.c ****     {
1296:My_Top/Drone_CAN/canard.c ****         ins->tx_queue = item;
1297:My_Top/Drone_CAN/canard.c ****         return;
1298:My_Top/Drone_CAN/canard.c ****     }
1299:My_Top/Drone_CAN/canard.c **** 
1300:My_Top/Drone_CAN/canard.c ****     CanardTxQueueItem* queue = ins->tx_queue;
1301:My_Top/Drone_CAN/canard.c ****     CanardTxQueueItem* previous = ins->tx_queue;
1302:My_Top/Drone_CAN/canard.c **** 
1303:My_Top/Drone_CAN/canard.c ****     while (queue != NULL)
1304:My_Top/Drone_CAN/canard.c ****     {
