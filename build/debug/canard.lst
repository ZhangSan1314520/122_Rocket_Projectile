 288:My_Top/Drone_CAN/canard.c **** CANARD_INTERNAL uint16_t calculateCRC(const CanardTxTransfer* transfer_object)
 289:My_Top/Drone_CAN/canard.c **** {
 290:My_Top/Drone_CAN/canard.c ****     uint16_t crc = 0xFFFFU;
 291:My_Top/Drone_CAN/canard.c **** #if CANARD_ENABLE_CANFD
 292:My_Top/Drone_CAN/canard.c ****     if ((transfer_object->payload_len > 7 && !transfer_object->canfd) ||
