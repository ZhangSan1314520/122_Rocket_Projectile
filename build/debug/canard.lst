1306:My_Top/Drone_CAN/canard.c ****         {
1307:My_Top/Drone_CAN/canard.c ****             if (queue == ins->tx_queue)
1308:My_Top/Drone_CAN/canard.c ****             {
ARM GAS  /tmp/ccSNdYhq.s 			page 31


1309:My_Top/Drone_CAN/canard.c ****                 item->next = queue;
1310:My_Top/Drone_CAN/canard.c ****                 ins->tx_queue = item;
1311:My_Top/Drone_CAN/canard.c ****             }
1312:My_Top/Drone_CAN/canard.c ****             else
1313:My_Top/Drone_CAN/canard.c ****             {
1314:My_Top/Drone_CAN/canard.c ****                 previous->next = item;
1315:My_Top/Drone_CAN/canard.c ****                 item->next = queue;
1316:My_Top/Drone_CAN/canard.c ****             }
1317:My_Top/Drone_CAN/canard.c ****             return;
1318:My_Top/Drone_CAN/canard.c ****         }
1319:My_Top/Drone_CAN/canard.c ****         else
1320:My_Top/Drone_CAN/canard.c ****         {
1321:My_Top/Drone_CAN/canard.c ****             if (queue->next == NULL)
1322:My_Top/Drone_CAN/canard.c ****             {
1323:My_Top/Drone_CAN/canard.c ****                 queue->next = item;
1324:My_Top/Drone_CAN/canard.c ****                 return;
1325:My_Top/Drone_CAN/canard.c ****             }
1326:My_Top/Drone_CAN/canard.c ****             else
1327:My_Top/Drone_CAN/canard.c ****             {
