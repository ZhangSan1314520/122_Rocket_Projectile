 294:My_Top/Drone_CAN/canard.c **** #else
 295:My_Top/Drone_CAN/canard.c ****     if (transfer_object->payload_len > 7)
 296:My_Top/Drone_CAN/canard.c **** #endif
 297:My_Top/Drone_CAN/canard.c ****     {
 298:My_Top/Drone_CAN/canard.c ****         crc = crcAddSignature(crc, transfer_object->data_type_signature);
 299:My_Top/Drone_CAN/canard.c ****         crc = crcAdd(crc, transfer_object->payload, transfer_object->payload_len);
 300:My_Top/Drone_CAN/canard.c **** #if CANARD_ENABLE_CANFD
 301:My_Top/Drone_CAN/canard.c ****         if (transfer_object->payload_len > 63 && transfer_object->canfd) {
 302:My_Top/Drone_CAN/canard.c ****             uint8_t empty = 0;
 303:My_Top/Drone_CAN/canard.c ****             uint8_t padding = (uint8_t)dlcToDataLength(dataLengthToDlc((uint16_t)((transfer_object-
 304:My_Top/Drone_CAN/canard.c ****             padding -= (uint8_t)((transfer_object->payload_len+2) % 63);
 305:My_Top/Drone_CAN/canard.c ****             for (uint8_t i=0; i<padding; i++) {
 306:My_Top/Drone_CAN/canard.c ****                 crc = crcAddByte(crc, empty);
 307:My_Top/Drone_CAN/canard.c ****             }
 308:My_Top/Drone_CAN/canard.c ****         }
 309:My_Top/Drone_CAN/canard.c **** #endif
 310:My_Top/Drone_CAN/canard.c ****     }
 311:My_Top/Drone_CAN/canard.c ****     return crc;
 312:My_Top/Drone_CAN/canard.c **** }
