  31:My_Top/System/HAL_System.cpp **** 
  32:My_Top/System/HAL_System.cpp ****     // 拼装 64 位计时器：
  33:My_Top/System/HAL_System.cpp ****     // tick_us 的高 32 位 = 之前的累加值（elapse_cnt × 2^32）
  34:My_Top/System/HAL_System.cpp ****     // tick_us 的低 32 位 = 当前 TIM 计数器值
  35:My_Top/System/HAL_System.cpp ****     // 先把当前的低 32 位清零（& ~0xFFFFFFFF），再或上新的计数器值
  36:My_Top/System/HAL_System.cpp ****     tick_us = (tick_us & (uint64_t)nub_reset) | current_cnt;
  37:My_Top/System/HAL_System.cpp **** 
  38:My_Top/System/HAL_System.cpp ****     return tick_us;
  39:My_Top/System/HAL_System.cpp **** }
