   6:My_Top/System/HAL_System.cpp **** // 静态成员变量定义
   7:My_Top/System/HAL_System.cpp **** // STM32 的 TIM 计数器是 32 位的，最大值 0xFFFFFFFF
   8:My_Top/System/HAL_System.cpp **** // 当计数器溢出（从 0xFFFFFFFF 回到 0）时，需要累加高 32 位
   9:My_Top/System/HAL_System.cpp **** // ============================================================
  10:My_Top/System/HAL_System.cpp **** uint64_t HAL_System::tick_us = 0;     // 64 位微秒计时器（高 32 位 + TIM 计数器）
  11:My_Top/System/HAL_System.cpp **** uint32_t HAL_System::tick_ms = 0;     // 32 毫秒计时器（由 tick_us 计算得到）
  12:My_Top/System/HAL_System.cpp **** 
  13:My_Top/System/HAL_System.cpp **** // ============================================================
  14:My_Top/System/HAL_System.cpp **** // 初始化函数
  15:My_Top/System/HAL_System.cpp **** // ============================================================
  16:My_Top/System/HAL_System.cpp **** void HAL_System::init(void)
  17:My_Top/System/HAL_System.cpp **** {
  18:My_Top/System/HAL_System.cpp ****     // 启动定时器中断（计数器开始计数）
  19:My_Top/System/HAL_System.cpp ****     HAL_TIM_Base_Start_IT(System_htim);
  20:My_Top/System/HAL_System.cpp **** 
  21:My_Top/System/HAL_System.cpp ****     // 注册 PeriodElapsed 回调函数
  22:My_Top/System/HAL_System.cpp ****     // 作用：当 TIM 计数器溢出时，自动调用 period_elapsed_callback()
  23:My_Top/System/HAL_System.cpp ****     // 这样可以累加高 32 位，实现 64 位精度的长时间计时stm32g4xx_hal_tim
  24:My_Top/System/HAL_System.cpp ****     HAL_TIM_RegisterCallback(System_htim, HAL_TIM_PERIOD_ELAPSED_CB_ID, period_elapsed_callback);
  25:My_Top/System/HAL_System.cpp **** }
  26:My_Top/System/HAL_System.cpp **** 
  27:My_Top/System/HAL_System.cpp **** 
  28:My_Top/System/HAL_System.cpp **** // ============================================================
  29:My_Top/System/HAL_System.cpp **** // 获取当前微秒数（64 位，精度由 TIM 决定）
  30:My_Top/System/HAL_System.cpp **** // ============================================================
ARM GAS  /tmp/ccePsSLK.s 			page 2


  31:My_Top/System/HAL_System.cpp **** uint64_t HAL_System::get_tick_us(void)
  32:My_Top/System/HAL_System.cpp **** {
  33:My_Top/System/HAL_System.cpp ****     // 读取当前 TIM 计数器的低 32 位
  34:My_Top/System/HAL_System.cpp ****     uint32_t current_cnt = __HAL_TIM_GET_COUNTER(System_htim);
  35:My_Top/System/HAL_System.cpp **** 
  36:My_Top/System/HAL_System.cpp ****     // 拼装 64 位计时器：
  37:My_Top/System/HAL_System.cpp ****     // tick_us 的高 32 位 = 之前的累加值（elapse_cnt × 2^32）
  38:My_Top/System/HAL_System.cpp ****     // tick_us 的低 32 位 = 当前 TIM 计数器值
  39:My_Top/System/HAL_System.cpp ****     // 先把当前的低 32 位清零（& ~0xFFFFFFFF），再或上新的计数器值
  40:My_Top/System/HAL_System.cpp ****     tick_us = (tick_us & (uint64_t)0xFFFFFFFF00000000) | current_cnt;
  41:My_Top/System/HAL_System.cpp **** 
  42:My_Top/System/HAL_System.cpp ****     return tick_us;
  43:My_Top/System/HAL_System.cpp **** }
  44:My_Top/System/HAL_System.cpp **** 
  45:My_Top/System/HAL_System.cpp **** // ============================================================
  46:My_Top/System/HAL_System.cpp **** // 获取当前毫秒数（32 位，由微秒计算得出）
  47:My_Top/System/HAL_System.cpp **** // ============================================================
  48:My_Top/System/HAL_System.cpp **** uint32_t HAL_System::get_tick_ms(void)
  49:My_Top/System/HAL_System.cpp **** {
  50:My_Top/System/HAL_System.cpp ****     // 微秒转毫秒（除以 1000）
  51:My_Top/System/HAL_System.cpp ****     tick_ms = get_tick_us() / 1000;
  52:My_Top/System/HAL_System.cpp ****     return tick_ms;
  53:My_Top/System/HAL_System.cpp **** }
  54:My_Top/System/HAL_System.cpp **** 
  55:My_Top/System/HAL_System.cpp **** // ============================================================
  56:My_Top/System/HAL_System.cpp **** // 延时函数（使用 FreeRTOS 的任务延时，释放 CPU）
  57:My_Top/System/HAL_System.cpp **** // ============================================================
  58:My_Top/System/HAL_System.cpp **** void HAL_System::delay_ms(uint32_t ms)
  59:My_Top/System/HAL_System.cpp **** {
  60:My_Top/System/HAL_System.cpp ****     vTaskDelay(pdMS_TO_TICKS(ms));
  61:My_Top/System/HAL_System.cpp **** }
