  44:My_Top/System/HAL_System.cpp **** // 获取当前毫秒数（32 位，由微秒计算得出）
  45:My_Top/System/HAL_System.cpp **** // ============================================================
  46:My_Top/System/HAL_System.cpp **** uint32_t HAL_System::get_tick_ms(void)
  47:My_Top/System/HAL_System.cpp **** {
  48:My_Top/System/HAL_System.cpp ****     // 微秒转毫秒（除以 1000）
  49:My_Top/System/HAL_System.cpp ****     tick_ms = get_tick_us() / 1000;
  50:My_Top/System/HAL_System.cpp ****     return tick_ms;
  51:My_Top/System/HAL_System.cpp **** }
  52:My_Top/System/HAL_System.cpp **** 
