  75:My_Top/System/BL24C16F.cpp **** // ============================================================
  76:My_Top/System/BL24C16F.cpp **** // 连续写入多个字节（自动处理页边界）
  77:My_Top/System/BL24C16F.cpp **** // ============================================================
  78:My_Top/System/BL24C16F.cpp **** bool BL24C16F::write(uint16_t addr, const uint8_t *buf, uint16_t len)
  79:My_Top/System/BL24C16F.cpp **** {
  80:My_Top/System/BL24C16F.cpp ****     if (buf == NULL || len == 0)
  81:My_Top/System/BL24C16F.cpp ****         return false;
  82:My_Top/System/BL24C16F.cpp ****     if (addr + len > EEPROM_SIZE)
  83:My_Top/System/BL24C16F.cpp ****         return false;
  84:My_Top/System/BL24C16F.cpp **** 
  85:My_Top/System/BL24C16F.cpp ****     while (len > 0)
  86:My_Top/System/BL24C16F.cpp ****     {
  87:My_Top/System/BL24C16F.cpp ****         // 计算当前页内还能写多少字节
  88:My_Top/System/BL24C16F.cpp ****         uint8_t page_remain = EEPROM_PAGE_SIZE - (addr % EEPROM_PAGE_SIZE);
  89:My_Top/System/BL24C16F.cpp ****         uint16_t chunk = (len < page_remain) ? len : page_remain;
  90:My_Top/System/BL24C16F.cpp **** 
  91:My_Top/System/BL24C16F.cpp ****         if (HAL_I2C_Mem_Write(_hi2c, EEPROM_DEV_ADDR << 1, addr,
  92:My_Top/System/BL24C16F.cpp ****                                EEPROM_ADDR_SIZE,
  93:My_Top/System/BL24C16F.cpp ****                                (uint8_t *)buf, chunk, 100) != HAL_OK)
  94:My_Top/System/BL24C16F.cpp ****         {
  95:My_Top/System/BL24C16F.cpp ****             return false;
  96:My_Top/System/BL24C16F.cpp ****         }
  97:My_Top/System/BL24C16F.cpp **** 
  98:My_Top/System/BL24C16F.cpp ****         // 等待内部写入完成
  99:My_Top/System/BL24C16F.cpp ****         _wait_write_complete();
 100:My_Top/System/BL24C16F.cpp **** 
 101:My_Top/System/BL24C16F.cpp ****         addr += chunk;
 102:My_Top/System/BL24C16F.cpp ****         buf  += chunk;
 103:My_Top/System/BL24C16F.cpp ****         len  -= chunk;
ARM GAS  /tmp/ccslA8Q6.s 			page 7


 104:My_Top/System/BL24C16F.cpp ****     }
 105:My_Top/System/BL24C16F.cpp ****     return true;
 106:My_Top/System/BL24C16F.cpp **** }
