  31:Lib/compute/pid/pid.cpp **** 
  32:Lib/compute/pid/pid.cpp **** float PID::update(float error, float nudge)
  33:Lib/compute/pid/pid.cpp **** {
  34:Lib/compute/pid/pid.cpp ****     _error = error;
  35:Lib/compute/pid/pid.cpp ****     _nudge = nudge;
  36:Lib/compute/pid/pid.cpp **** 
  37:Lib/compute/pid/pid.cpp ****     // Proportional term
  38:Lib/compute/pid/pid.cpp ****     _P = _kp * error;
  39:Lib/compute/pid/pid.cpp **** 
  40:Lib/compute/pid/pid.cpp ****     // Integral term
  41:Lib/compute/pid/pid.cpp ****     // _integral += error * _dt;
  42:Lib/compute/pid/pid.cpp ****     _update_I(error);
  43:Lib/compute/pid/pid.cpp **** 
  44:Lib/compute/pid/pid.cpp ****     // Derivative term
  45:Lib/compute/pid/pid.cpp ****     // float derivative = (error - _prev_error) / _dt;
  46:Lib/compute/pid/pid.cpp ****     _D = _kd * (error - _prev_error) / _dt;
  47:Lib/compute/pid/pid.cpp **** 
  48:Lib/compute/pid/pid.cpp ****     // Calculate output
  49:Lib/compute/pid/pid.cpp ****     _output = _P + _I - _D + nudge;
  50:Lib/compute/pid/pid.cpp **** 
  51:Lib/compute/pid/pid.cpp ****     // Clamp output
  52:Lib/compute/pid/pid.cpp ****     if (_output > _max)
  53:Lib/compute/pid/pid.cpp ****         _output = _max;
  54:Lib/compute/pid/pid.cpp ****     else if (_output < _min)
  55:Lib/compute/pid/pid.cpp ****         _output = _min;
  56:Lib/compute/pid/pid.cpp **** 
  57:Lib/compute/pid/pid.cpp ****     // Save error to previous error
  58:Lib/compute/pid/pid.cpp ****     _prev_error = error;
  59:Lib/compute/pid/pid.cpp **** 
  60:Lib/compute/pid/pid.cpp ****     return _output;
  61:Lib/compute/pid/pid.cpp **** }
