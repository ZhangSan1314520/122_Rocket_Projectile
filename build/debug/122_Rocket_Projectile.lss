void HAL_System::period_elapsed_callback(TIM_HandleTypeDef *htim)
{
    // TIM 溢出一次 = 增加了 2^32 个计数单位
    // 1 << 32 = 0x100000000 = 4294967296
    // tick_us 高 32 位自动加 1（因为累加到这个数）
    tick_us += (uint64_t)1 << 32;
